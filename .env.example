# Backend server
PORT=8765
USER_AGENT="AltaDriveEstimator/1.0 (contact@example.com)"
CAMERA_CACHE_MS=120000
CAMERA_CACHE_SEC=120

# Public/keyless upstreams used by the backend today.
# If you replace OSRM/Nominatim with a paid provider, put that provider's URL/token here
# and keep the real .env file out of git.
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
OSRM_URL=http://router.project-osrm.org/route/v1/driving
COTTONWOOD_ROAD_INFO_URL=https://cottonwoodcanyons.udot.utah.gov/road-information/
UDOT_CCTV_URL_TEMPLATE=https://www.udottraffic.utah.gov/map/Cctv/{id}
NWS_POINTS_URL_TEMPLATE=https://api.weather.gov/points/{lat},{lon}
